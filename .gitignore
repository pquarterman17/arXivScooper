# PDFs (large binaries — keep locally, don't track in git)
papers/*.pdf

# Per-paper figures and arXiv-fetch staging — both are junctions on
# Windows pointing into OneDrive\arXivScooper. Treat the entire
# trees as user-private data; they were removed from tracking in
# `aba37e5` (2026-04-30).
figures/
inbox/

# User research artifacts that live in OneDrive\arXivScooper (per
# the user_config/paths.toml override). Locally they may or may not
# exist at these paths depending on each user's setup; either way
# they're never committed.
references.bib
references.txt
digests/digest_*.html
digests/*.json
weekly_digest.html

# SQLite temp files
*.db-journal
*.db-wal
*.db-shm
.scq_tmp.db

# Canonical paper database — user-private. Bootstrap a fresh DB with
# `scq init` (plan #2 / #13). Path is configurable via SCQ_DB_PATH or
# data/user_config/paths.toml.
data/arxiv_scooper.db
# Pre-rename names kept ignored during transition.
data/scientific_litter_scoop.db
data/scq_papers.db

# Cross-run digest dedup state (sent arXiv IDs). Runtime state, not source:
# CI persists it via actions/cache (see .github/workflows/arxiv_digest.yml);
# locally it's just untracked. Missing file → "remember nothing" (fail-open).
data/digest_state.json

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Python
__pycache__/
*.pyc

# Node
node_modules/
# Vite production-bundle output (plan #18). Build artifacts; not tracked.
dist/

# Auto-memory (Cowork session state)
.auto-memory/

# Overleaf sync (Git cloned repo — don't track)
.overleaf/

# Editor
*.swp
*.swo
*~

# Claude local settings + transient agent worktrees + scheduled-task locks
.claude/settings.local.json
.claude/worktrees/
.claude/scheduled_tasks.lock

# Personal launcher with hardcoded Windows paths
tools/run_digest.bat

# Scratch files from ad-hoc GitHub API updates
tools/update_digest.json
tools/update_workflow.json

# Inbox runtime state
inbox/processed/

# Local planning docs (not tracked)
plans/

# User config overrides — only commit the *.example starter templates,
# never the real files (which contain emails, paths, and other personal data)
data/user_config/*.json
data/user_config/*.toml

# Legacy: superseded by data/user_config/digest.json. Keep the file ignored
# so leftover working copies don't get re-tracked. Migration is automatic
# in tools/arxiv_digest.py — but the canonical location is now user_config.
email_recipients.json

# Legacy: pre-DB user state backup. Only ever read by
# `tools/init_database.py --migrate` (one-shot, completed long ago).
# Database tables are now canonical. Kept untracked so old working copies
# can stick around for reference without re-entering git.
notes.json
pending_papers.json
